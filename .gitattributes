# Ensure consistent line endings
* text=auto eol=lf

# Unity YAML files (keep diffs readable)
*.meta text eol=lf
*.unity text eol=lf
*.prefab text eol=lf
*.asset text eol=lf
*.mat text eol=lf
*.anim text eol=lf
*.controller text eol=lf
*.overrideController text eol=lf
*.playable text eol=lf
*.shader text eol=lf
*.cginc text eol=lf

# Treat binary files as binary
*.png binary
*.jpg binary
*.jpeg binary
*.tga binary
*.psd binary
*.wav binary
*.mp3 binary
*.mp4 binary
*.fbx binary
*.blend binary

