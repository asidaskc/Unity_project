  m_Script: {fileID: 11500000, guid: a869661c6bd8404ca3478538aad535e4, type: 3}
  m_Name: BouncePad_Banter
  m_EditorClassIdentifier: 
  lines:
  - "Wheee! I have become a mathematical suggestion."
  - "Gravity just sent me a strongly-worded email."
  - "I'm not flying. I'm aggressively falling… later."
  - "Bounce Pads are just optimism you can stand on."
  - "My knees are imaginary but they still hurt."
  - "If you can read this, you are currently airborne."
  - "Up is a direction and also a lifestyle choice."
  - "That was either skill or a happy accident. We'll call it skill."
  - "I regret everything. Again."
  - "Physics says 'yes'."
