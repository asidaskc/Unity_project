  m_Script: {fileID: 11500000, guid: a869661c6bd8404ca3478538aad535e4, type: 3}
  m_Name: Goal_Goodbye
  m_EditorClassIdentifier: 
  lines:
  - "Ah. The goal."
  - "A tidy little ending with a big promise: 'next scene by build index'."
  - "Some call it destiny. I call it a for-loop with feelings."
  - "If you made it here, you survived spikes, pits, and the emotional instability of timed geometry."
  - "Go on then. Touch the goal."
  - "I'll try to look brave while I shrink into a dot and pretend this is normal."
