  m_Script: {fileID: 11500000, guid: a869661c6bd8404ca3478538aad535e4, type: 3}
  m_Name: Checkpoint_Philosophy
  m_EditorClassIdentifier: 
  lines:
  - "A checkpoint! A little memory you can borrow."
  - "I touched it. The universe nodded."
  - "If I die now, please notify my square relatives."
  - "This is the part where the level forgives you. Briefly."
  - "Saving progress: because character development is hard."
  - "My past self left this here for my future self. What a hero."
  - "Checkpoint acquired: anxiety reduced by 12%."
  - "I feel… bookmarked."
  - "Nothing says 'growth' like a new respawn point."
