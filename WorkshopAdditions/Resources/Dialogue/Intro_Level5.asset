  m_Script: {fileID: 11500000, guid: a869661c6bd8404ca3478538aad535e4, type: 3}
  m_Name: Intro_Level5
  m_EditorClassIdentifier: 
  lines:
  - "Level 5: 'Switchback Serenade.' (Yes, levels get titles. It's the law.)"
  - "Good news: you’re stronger. Bad news: the level knows that."
  - "See that moving platform? It’s not your friend. It’s just employed here."
  - "Timed platforms ahead will blink in patterns. Try to blink less than they do."
  - "And remember: checkpoints are like promises—meaningful only when kept."
